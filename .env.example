# smtp2graph experimental configuration contract.
# This file contains only safe development values and secret references.
# Do not copy it to a production .env file. Production material is managed by
# SOPS + age and Docker Secrets after the applicable roadmap gates.

# Public and environment-specific inputs.
CONFIG_CONTRACT_VERSION=experimental-v1
DEPLOY_ENVIRONMENT=development
SMTP_BIND_ADDRESS=127.0.0.1
SMTP_LISTEN_PORT=2525
SMTP_MAX_MESSAGE_BYTES=26214400
SMTP_MAX_SESSIONS_PER_IP=5
SMTP_MESSAGES_PER_MINUTE=30
SMTP_ALLOWED_SOURCE_CIDRS=127.0.0.1/32
SMTP_ALLOWED_SENDER_ADDRESSES=noreply@example.invalid
GRAPH_SENDER_MAILBOX=noreply@example.invalid
NONPRODUCTION_RECIPIENT_ALLOWLIST=recipient@example.invalid
QUEUE_MAX_BYTES=1073741824
QUEUE_REJECT_THRESHOLD_PERCENT=80
FAILED_PAYLOAD_RETENTION_DAYS=7
LOG_RETENTION_DAYS=30
SWARM_STACK_NAME=smtp2graph
SWARM_OVERLAY_NETWORK=smtp2graph_internal

# Docker Secret references only; never place secret values here.
GRAPH_TENANT_ID_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
GRAPH_CLIENT_ID_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
GRAPH_CREDENTIAL_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
SMTP_CREDENTIALS_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
TLS_CERTIFICATE_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
TLS_PRIVATE_KEY_SECRET_NAME=REPLACE_WITH_VERSIONED_SECRET_NAME
